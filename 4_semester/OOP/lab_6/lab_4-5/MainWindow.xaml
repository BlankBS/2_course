<Window x:Class="lab_4_5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:lab_4_5.ViewModels"
        xmlns:controls="clr-namespace:lab_4_5.Controls"
        Title="PUBG Skin Market" Height="650" Width="1050"
        Icon="pack://application:,,,/Resources/Icons/app.ico" 
        AllowDrop="True" Drop="Image_Drop"
        WindowStyle="None" 
        WindowStartupLocation="CenterScreen"
        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" >

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PubgButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Path Data="M 10,0 L 100,0 L 110,15 L 100,30 L 10,30 L 0,15 Z" 
                          Fill="{TemplateBinding Background}" 
                          Stretch="Fill" 
                          Stroke="{TemplateBinding BorderBrush}" StrokeThickness="1"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Price}" Value="1000">
                    <Setter Property="Foreground" Value="Red"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </MultiDataTrigger>

                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Grid Background="{DynamicResource PrimaryBG}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource SecondaryBG}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <Image Source="pack://application:,,,/Resources/Icons/app.ico" Width="20" Height="20" Margin="0,0,10,0"/>
                <TextBlock Text="PUBG SKIN MARKET" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal" Margin="10,0">
                    <Button Content="{DynamicResource m_Undo}" Command="{Binding UndoCommand}" 
                            Style="{StaticResource PubgButtonStyle}" Width="80" Height="25" Margin="5"/>
                    <Button Content="{DynamicResource m_Redo}" Command="{Binding RedoCommand}" 
                            Style="{StaticResource PubgButtonStyle}" Width="80" Height="25" Margin="5"/>
                </StackPanel>
                <Button Content="—" Click="MinimizeWin" Style="{StaticResource CaptionButtonStyle}"/>
                <Button Content="☐" Click="MaximizeWin" Style="{StaticResource CaptionButtonStyle}"/>
                <Button Content="✕" Click="CloseWin"    Style="{StaticResource CloseButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SecondaryBG}" Margin="10" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="PUBG MARKET" Foreground="{DynamicResource AccentColor}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                        <Button Content="{DynamicResource m_Profile}" Click="OpenProfile_Click" 
                                    Background="Transparent" 
                                    Foreground="{DynamicResource AccentColor}" 
                                    BorderThickness="0" FontWeight="Bold" Margin="0,10,10,0"
                                HorizontalAlignment="Left"/>
                        <CheckBox Content="{DynamicResource m_Admin}" 
                                  IsChecked="{Binding IsAdmin}" 
                                  Foreground="{DynamicResource MainText}" 
                                  FontWeight="Bold"
                                  Margin="0,10,0,15"/>
                        <Label Content="{DynamicResource m_Search}" Foreground="{DynamicResource MainText}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>
                        <Label Content="{DynamicResource m_Category}" Foreground="{DynamicResource MainText}"/>
                        <Slider Minimum="0" Maximum="1000" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MaxPrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
                        <TextBlock Foreground="{DynamicResource AccentColor}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right">
                            <Run Text="{DynamicResource m_PriceTo}"/>
                            <Run Text="{Binding MaxPrice, StringFormat={}{0:F0}}"/>
                            <Run Text="{DynamicResource m_Currency}"/>
                        </TextBlock>
                        <Button Content="{DynamicResource m_Add}" 
                                Command="{Binding AddCommand}" 
                                Style="{StaticResource PubgButtonStyle}" 
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                                Background="{DynamicResource AccentColor}"
                                Height="35" 
                                Margin="0,15"/>
                        <ComboBox ItemsSource="{Binding Categories}" 
                                  SelectedItem="{Binding SelectedCategory}" 
                                  Margin="0,5,0,10"
                                  Style="{StaticResource PubgComboBoxStyle}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="CategoryText" Text="{Binding}" Foreground="{DynamicResource MainText}"/>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="Cat_All">
                                            <Setter TargetName="CategoryText" Property="Text" Value="{DynamicResource Cat_All}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="Cat_Weapon">
                                            <Setter TargetName="CategoryText" Property="Text" Value="{DynamicResource Cat_Weapon}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="Cat_Clothing">
                                            <Setter TargetName="CategoryText" Property="Text" Value="{DynamicResource Cat_Clothing}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="Cat_Vehicle">
                                            <Setter TargetName="CategoryText" Property="Text" Value="{DynamicResource Cat_Vehicle}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <GroupBox Grid.Row="1" Header="{DynamicResource m_Basket}" Foreground="{DynamicResource AccentColor}" Margin="10" BorderBrush="#444444">
                        <DockPanel>
                            <Button DockPanel.Dock="Bottom" 
                                    Content="{DynamicResource m_Checkout}" 
                                    Command="{Binding CheckoutCommand}" 
                                    Style="{StaticResource CheckoutButtonStyle}" 
                                    Height="35" 
                                    Margin="5"/>
                            <TextBlock DockPanel.Dock="Bottom" Foreground="White" HorizontalAlignment="Center" Margin="5">
                                <Run Text="{DynamicResource m_Total}"/>
                                <Run Text="{Binding CartTotal, StringFormat={}{0:F2}}"/>
                                <Run Text="{DynamicResource m_Currency}"/>
                            </TextBlock>
                            <ListBox ItemsSource="{Binding CartItems}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Width="200">
                                            <Button DockPanel.Dock="Right" Content="×" Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="Red" BorderThickness="0"/>
                                            <TextBlock Text="{Binding ShortName}" Foreground="{DynamicResource MainText}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Price, StringFormat={}{0}$}" Foreground="{DynamicResource AccentColor}" Margin="20,0,0,0"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </Border>
            <DockPanel Grid.Column="1" Margin="10">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FilteredSkins}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:SkinCard Width="230" Margin="5" HorizontalAlignment="Left"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Grid>

</Window>