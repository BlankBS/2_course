<Window x:Class="lab_4_5.Views.AddSkinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить новый скин" Height="750" Width="400"
        Background="#1A1A1A" WindowStartupLocation="CenterOwner"
		Icon="pack://application:,,,/Resources/Icons/app.ico">
    <StackPanel Margin="20">
        <TextBlock Text="{DynamicResource m_NewItem}" x:Name="txtHeader" Foreground="#F2A900" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Label Content="{DynamicResource m_Name}" Foreground="White"/>
        <TextBox x:Name="txtName" Margin="0,5,0,10"/>

        <Label Content="{DynamicResource m_Cost}" Foreground="White"/>
        <TextBox x:Name="txtPrice" Margin="0,5,0,10"/>

        <Label Content="{DynamicResource m_Quantity}" Foreground="White"/>
		<TextBox x:Name="txtQuantity" Text="1" Margin="0,5,0,10" Padding="5" PreviewTextInput="NumberValidationTextBox"/>

        <Label Content="{DynamicResource m_Category}" Foreground="White"/>
        <ComboBox x:Name="cmbCategory" Margin="0,5,0,10" Padding="5">
            <ComboBox.Items>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Cat_Weapon</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Cat_Clothing</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Cat_Vehicle</System:String>
            </ComboBox.Items>

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock x:Name="txt" Text="{Binding}"/>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding}" Value="Cat_Weapon">
                            <Setter TargetName="txt" Property="Text" Value="{DynamicResource Cat_Weapon}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding}" Value="Cat_Clothing">
                            <Setter TargetName="txt" Property="Text" Value="{DynamicResource Cat_Clothing}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding}" Value="Cat_Vehicle">
                            <Setter TargetName="txt" Property="Text" Value="{DynamicResource Cat_Vehicle}"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <Label Content="{DynamicResource m_Rarity}" Foreground="White"/>
        <ComboBox x:Name="cmbRarity" Margin="0,5,0,10">
            <ComboBoxItem Content="Common"/>
            <ComboBoxItem Content="Rare"/>
            <ComboBoxItem Content="Epic"/>
            <ComboBoxItem Content="Legendary" IsSelected="True"/>
        </ComboBox>

        <Label Content="{DynamicResource m_Preview}" Foreground="White" Margin="0,10,0,0"/>
		<Border BorderBrush="#F2A900" BorderThickness="1" Height="150" Margin="0,5" CornerRadius="5" Background="#0D0D0D">
			<Image x:Name="imgPreview" Stretch="Uniform" Margin="5"
				   Source="/Resources/Images/placeholder.png"/>
		</Border>

        <Button x:Name="btnSelectImage" Content="{DynamicResource m_ChoosePicture}" Click="btnSelectImage_Click" Margin="0,10"/>
        <TextBlock x:Name="lblImagePath" Text="{DynamicResource m_PictureNotSelected}" Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>

        <UniformGrid Columns="2" Margin="0,20,0,0">
            <Button Content="{DynamicResource m_Save}" Click="btnSave_Click" Background="#F2A900" FontWeight="Bold" Margin="5"/>
            <Button Content="{DynamicResource m_Decline}" Click="btnCancel_Click" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</Window>