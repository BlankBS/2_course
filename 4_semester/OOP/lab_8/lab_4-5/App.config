<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
	</startup>
	<connectionStrings>
		<add name="DefaultConnection"
       connectionString="Data Source=(LocalDB)\MSSQLLocalDB;Initial Catalog=test;Integrated Security=True"
       providerName="System.Data.SqlClient" />

		<add name="MasterConnection"
			 connectionString="Data Source=(LocalDB)\MSSQLLocalDB;Initial Catalog=master;Integrated Security=True"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>